# =====================================================
# Variabel Lingkungan (Environment Variables) - Backend
# -----------------------------------------------------
# PENTING:
# 1. Salin file ini menjadi `.env`
# 2. Isi nilai-nilai di bawah dengan kredensial yang asli
# 3. JANGAN PERNAH commit file `.env` ke public repository
# =====================================================

# 1. Konfigurasi Server
# -----------------------------------------------------
PORT=5000
NODE_ENV=development # Ubah ke 'production' saat deploy

# Origin frontend yang boleh mengakses API saat NODE_ENV=production.
# Pisahkan dengan koma jika ada lebih dari satu.
# Contoh: ALLOWED_ORIGINS=https://absensi-klinik.example.com,https://www.absensi-klinik.example.com
ALLOWED_ORIGINS=

# Limit payload JSON API. Gunakan 7mb jika FACE_PROVIDER=opencv_sface karena browser
# mengirim image data URL ke backend sebelum backend meneruskan ke face service.
JSON_BODY_LIMIT=7mb

# 2. Supabase Configuration (PostgreSQL Database)
# -----------------------------------------------------
# Dapatkan di: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxx.supabase.co

# Gunakan SERVICE_ROLE KEY (bukan Anon Key) untuk bypass Row Level Security
# Dapatkan di: Supabase Dashboard -> Project Settings -> API -> Project API Keys
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR....

# 3. Keamanan (Authentication)
# -----------------------------------------------------
# Kunci rahasia untuk membuat JSON Web Token (JWT)
# Gunakan string acak yang panjang, contoh generasi via node: `require('crypto').randomBytes(64).toString('hex')`
JWT_SECRET=super_secret_jwt_key_please_change_this_for_production
JWT_EXPIRES_IN=8h # Token berlaku 8 jam (1 shift_kerja)

# 4. Keamanan Lanjutan (Opsional)
# -----------------------------------------------------
# Kecepatan batasan request (Rate Limiting)
# RATE_LIMIT_WINDOW_MS=900000 # 15 Menit
# RATE_LIMIT_MAX_REQ=100

# 5. Face AI Provider (Opsional)
# -----------------------------------------------------
# faceapi       = default, descriptor diekstrak di browser seperti flow lama.
# opencv_sface  = backend mengirim foto RAM-only ke Hugging Face face-service.
FACE_PROVIDER=faceapi

# Wajib jika FACE_PROVIDER=opencv_sface.
FACE_SERVICE_URL=https://<username>-klinik-face-service.hf.space
FACE_SERVICE_API_KEY=<same-as-hugging-face-secret>
FACE_SERVICE_TIMEOUT_MS=10000
FACE_THRESHOLD_DEFAULT=0.50
MAX_FACE_IMAGE_BYTES=5242880
